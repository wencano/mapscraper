# Local Homebrew Postgres (or Docker mapped to localhost):
# DATABASE_URL="postgresql://mapscraper:mapscraper@localhost:5432/mapscraper?schema=public"

# Docker Compose / Dokploy (hostname = service name "db"):
DATABASE_URL="postgresql://mapscraper:mapscraper@db:5432/mapscraper?schema=public"

POSTGRES_USER=mapscraper
POSTGRES_PASSWORD=mapscraper
POSTGRES_DB=mapscraper
APP_PORT=3000

NEXT_PUBLIC_APP_NAME="MapScraper"
OVERPASS_URL="https://z.overpass-api.de/api/interpreter"
NOMINATIM_URL="https://nominatim.openstreetmap.org"
SCRAPER_USER_AGENT="MapScraperDemo/1.0 (demo leadgen; contact: demo@localhost)"
